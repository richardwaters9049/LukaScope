{
  "name": "lukascope",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build:frontend": "bun run --cwd frontend build",
    "build:backend": "bun run --cwd backend build",
    "lint:frontend": "bun run --cwd frontend lint",
    "test:frontend": "bun run --cwd frontend test",
    "test:backend": "bun run --cwd backend test",
    "test:ai": "cd backend/ai && pytest",
    "test": "bun run test:frontend && bun run test:backend",
    "test:coverage": "bun run --cwd frontend test:coverage && bun run --cwd backend test:coverage"
  }
}
