{
  "name": "lukascope",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "frontend"
  ],
  "overrides": {
    "flatted": "3.4.2",
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "cd backend && .venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 3001",
    "dev:worker": "cd backend && .venv/bin/python -m app.worker",
    "build:frontend": "bun run --cwd frontend build",
    "build:backend": "cd backend && .venv/bin/python -m compileall app",
    "lint:frontend": "bun run --cwd frontend lint",
    "lint:backend": "cd backend && .venv/bin/python -m compileall app",
    "test:frontend": "bun run --cwd frontend test",
    "test:backend": "cd backend && .venv/bin/pytest",
    "test:ai": "cd backend/ai && .venv/bin/pytest",
    "test": "bun run test:frontend && bun run test:backend",
    "test:coverage": "bun run --cwd frontend test:coverage && cd backend && .venv/bin/pytest --cov=app --cov=ai"
  }
}
