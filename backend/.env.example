# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/lukascope"

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# JWT secret key - generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT expiration time (e.g., 24h, 7d, 30d)
JWT_EXPIRES_IN="24h"

# ============================================
# AWS S3 CONFIGURATION (Optional - for file storage)
# ============================================
# AWS region
AWS_REGION="us-east-1"

# AWS access key ID
AWS_ACCESS_KEY_ID="your-aws-access-key-id"

# AWS secret access key
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# S3 bucket name
S3_BUCKET="lukascope-samples"

# ============================================
# AI/ML SERVICE CONFIGURATION
# ============================================
# AI service URL (for inference)
AI_SERVICE_URL="http://localhost:8000"

# Model version
MODEL_VERSION="YOLOv8n+XGBoost-v1.2"

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Password hashing rounds (default: 10)
BCRYPT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100