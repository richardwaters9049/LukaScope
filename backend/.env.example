# ============================================
# SERVER CONFIGURATION
# ============================================
# Runtime environment (development, production, test)
NODE_ENV=development

# Frontend URL(s) for CORS — comma-separated for multiple origins
FRONTEND_URL="http://localhost:3000"

# Persistence and queue
DATABASE_URL="sqlite:///./data/lukascope.db"
REDIS_URL="redis://localhost:6379/0"

# File-backed uploads, heatmaps, datasets, and model artifacts
STORAGE_ROOT="./data/storage"

# Active model metadata
ACTIVE_MODEL_VERSION="heuristic-v0.1"
ACTIVE_MODEL_PATH="./models/active/model.pt"

# Local testing convenience. Docker should use Redis workers.
RUN_JOBS_INLINE=false
