// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MODEL
// ============================================
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         UserRole   @default(CLINICIAN)
  isActive     Boolean    @default(true)
  analyses     Analysis[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([email])
}

// ============================================
// USER ROLES
// ============================================
enum UserRole {
  ADMIN          // Full access to all features
  CLINICIAN      // Standard medical professional
  RESEARCHER     // Read-only access for research purposes
}

// ============================================
// ANALYSIS MODEL
// ============================================
model Analysis {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sampleId      String      @unique
  status        AnalysisStatus @default(PENDING)
  classification String?
  confidence    Float?
  totalCells    Int?
  modelVersion  String?
  cellCounts    CellCount?
  files         File[]
  history       AnalysisHistory[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([sampleId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// ANALYSIS STATUS
// ============================================
enum AnalysisStatus {
  PENDING       // Uploaded, waiting for processing
  PROCESSING    // AI analysis in progress
  COMPLETED     // Analysis complete
  FAILED        // Analysis failed
}

// ============================================
// CELL COUNT MODEL
// ============================================
model CellCount {
  id          String   @id @default(uuid())
  analysisId  String   @unique
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  normal      Int      @default(0)
  abnormal    Int      @default(0)
  lymphocytes Int      @default(0)
  myeloblasts Int      @default(0)
  neutrophils Int      @default(0)
  monocytes   Int      @default(0)
  eosinophils Int      @default(0)
  basophils   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ============================================
// FILE MODEL
// ============================================
model File {
  id         String     @id @default(uuid())
  analysisId String
  analysis   Analysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  fileType   FileType
  storageKey String
  url        String
  mimeType   String
  fileSize   Int
  createdAt  DateTime   @default(now())

  @@index([analysisId])
}

// ============================================
// FILE TYPE
// ============================================
enum FileType {
  ORIGINAL        // Original uploaded image
  ANNOTATED       // AI-annotated image with bounding boxes
  HEATMAP         // Explainability heatmap
  GRADIENT        // Gradient-based explainability
  SHAP            // SHAP-based explainability
  THUMBNAIL       // Thumbnail version
}

// ============================================
// ANALYSIS HISTORY MODEL
// ============================================
model AnalysisHistory {
  id            String   @id @default(uuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  event         String
  description   String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([analysisId])
  @@index([createdAt])
}